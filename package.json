{
  "name": "tallyprime-setup",
  "version": "1.0.0",
  "description": "TallyPrime to PostgreSQL Pipeline - Environment Setup",
  "main": "setup.js",
  "bin": "setup.js",
  "scripts": {
    "start": "node setup.js",
    "build:win": "pkg setup.js --target node18-win-x64 --output dist/tallyprime-setup.exe --compress GZip"
  },
